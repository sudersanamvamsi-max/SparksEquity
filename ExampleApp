const STORAGE_KEY = 'sparkRepairProjects_v1';
const PRICES_KEY  = 'sparkRepairPrices_v1';

function loadPriceOverrides() {
  try { return JSON.parse(localStorage.getItem(PRICES_KEY) || '{}'); } catch { return {}; }
}
function savePriceOverrides() {
  try { localStorage.setItem(PRICES_KEY, JSON.stringify(state.priceOverrides)); } catch {}
}

function loadProjects() {
  try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); }
  catch { return []; }
}

function saveProjects(list) {
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(list));
  } catch {
    // If quota exceeded (likely due to photos), retry without photo data
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(list.map(p => ({ ...p, photos: {} }))));
    } catch {}
  }
}

function saveCurrentState() {
  if (!state.currentProjectId) return;
  const list = loadProjects();
  const snap = {
    id: state.currentProjectId,
    name: state.currentProjectName,
    savedAt: new Date().toISOString(),
    items: state.items,
    photos: state.photos,
    bathroomInstances: state.bathrooms.instances,
  };
  const idx = list.findIndex(p => p.id === state.currentProjectId);
  if (idx >= 0) list[idx] = snap; else list.unshift(snap);
  saveProjects(list);
}

let _saveTimer;
function scheduleSave() {
  clearTimeout(_saveTimer);
  _saveTimer = setTimeout(saveCurrentState, 800);
}


function openSettings() {
  refreshPriceStatus();
  document.getElementById('settings-modal').classList.remove('hidden');
}
function closeSettings() {
  document.getElementById('settings-modal').classList.add('hidden');
}
function refreshPriceStatus() {
  const count = Object.keys(state.priceOverrides).length;
  const el = document.getElementById('price-status');
  const resetBtn = document.getElementById('reset-prices-btn');
  if (count > 0) {
    el.textContent = `Custom prices active — ${count} item${count !== 1 ? 's' : ''} overridden`;
    el.className = 'mb-4 px-4 py-3 rounded-xl text-sm bg-orange-50 text-orange-700';
    resetBtn.classList.remove('hidden');
  } else {
    el.textContent = 'Using default prices';
    el.className = 'mb-4 px-4 py-3 rounded-xl text-sm bg-gray-50 text-gray-500';
    resetBtn.classList.add('hidden');
  }
}

document.getElementById('settings-bg').addEventListener('click', closeSettings);
document.getElementById('settings-close').addEventListener('click', closeSettings);


document.getElementById('price-csv-input').addEventListener('change', e => {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = ev => {
    const rows = parseCSV(ev.target.result);
    let updated = 0;
    rows.forEach(row => {
      const id = row.id?.trim();
      const cost = parseFloat(row.cost);
      if (id && !isNaN(cost) && cost >= 0) { state.priceOverrides[id] = cost; updated++; }
    });
    savePriceOverrides();
    refreshPriceStatus();
    render();
    alert(`${updated} price${updated !== 1 ? 's' : ''} updated successfully.`);
  };
  reader.readAsText(file);
  e.target.value = '';
});

document.getElementById('reset-prices-btn').addEventListener('click', () => {
  if (!confirm('Reset all prices to defaults?')) return;
  state.priceOverrides = {};
  savePriceOverrides();
  refreshPriceStatus();
  render();
});

// Modal buttons (outside #app, bound once)
document.getElementById('modal-confirm').addEventListener('click', confirmModal);
document.getElementById('modal-cancel').addEventListener('click', closeModal);
document.getElementById('modal-bg').addEventListener('click', closeModal);
document.getElementById('modal-input').addEventListener('keydown', e => {
  if (e.key === 'Enter') confirmModal();
  if (e.key === 'Escape') closeModal();
});

// ============================================================
// PARTIAL UPDATE (avoids full re-render on qty input)
// ============================================================
function updateTotalsInPlace(changedId) {
  const itemDef = findItemDef(changedId);
  if (!itemDef) return;
  const s = state.items[changedId];
  const t = calcItem(itemDef, s);

  const toggleBtn = document.querySelector(`[data-action="toggle-item"][data-id="${changedId}"]`);
  const card = toggleBtn?.closest('[data-item-card]');
  if (card) {
    const el = card.querySelector('.font-bold.text-base.flex-shrink-0');
    if (el) { el.textContent = t > 0 ? fmtTotal(t) : '—'; el.className = `font-bold text-base flex-shrink-0 ${t > 0 ? 'text-orange-600' : 'text-gray-200'}`; }
  }
  // Update group header total if item is inside a group
  const groupCard = toggleBtn?.closest('[data-group-card]');
  if (groupCard) {
    const gid = groupCard.dataset.gid;
    const group = GROUPS[gid];
    if (group) {
      const isBath = changedId.includes(':');
      const bathId = isBath ? changedId.split(':')[0] : null;
      const groupTotal = group.ids.reduce((sum, id) => {
        const sid = bathId ? `${bathId}:${id}` : id;
        const def = findItemDef(sid);
        return sum + (def ? calcItem(def, state.items[sid]) : 0);
      }, 0);
      const totalEl = groupCard.querySelector('[data-group-total]');
      if (totalEl) {
        totalEl.textContent = groupTotal > 0 ? fmtTotal(groupTotal) : '—';
        totalEl.className = `font-bold text-base flex-shrink-0 ml-2 ${groupTotal > 0 ? 'text-orange-600' : 'text-gray-200'}`;
      }
    }
  }

  const hdr = document.querySelector('.text-5xl.font-bold');
  if (hdr) hdr.textContent = fmtTotal(calcRunningTotal());

  const cat = CATEGORIES[state.currentCat];
  const ct = calcCategoryTotal(cat);
  const tabSpan = document.querySelector(`[data-action="switch-cat"][data-index="${state.currentCat}"] span`);
  if (tabSpan) tabSpan.textContent = ct > 0 ? fmtTotal(ct) : '';

  const secEl = document.querySelector('.text-xs.text-gray-400.mt-1\\.5.truncate');
  if (secEl) {
    const n = CATEGORIES.filter(c => calcCategoryTotal(c) > 0).length;
    secEl.textContent = `${state.currentProjectName} · ${n} active section${n !== 1 ? 's' : ''}`;
  }
}

// ============================================================
// BOOT
// ============================================================
(function boot() {
  state.priceOverrides = loadPriceOverrides();
  const projects = loadProjects();
  if (projects.length > 0) {
    loadProjectIntoState(projects[0]);
  } else {
    state.currentProjectId = `proj_${Date.now()}`;
    state.currentProjectName = 'New Estimate';
    initState();
    saveCurrentState();
  }
  render();
  window.addEventListener('visibilitychange', () => { if (document.hidden) saveCurrentState(); });
  window.addEventListener('pagehide', saveCurrentState);
  window.addEventListener('freeze', saveCurrentState);
})();
</script>

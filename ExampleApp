// STATE
// ============================================================
const state = {
  currentCat: 0,
  showSummary: false,
  currentProjectId: null,
  currentProjectName: 'New Estimate',
  items: {},
  photos: {},
  priceOverrides: {},
  expandedGroups: [],
  bathrooms: {
    instances: [{ id: 'b1', name: 'Bathroom 1' }, { id: 'b2', name: 'Bathroom 2' }],
    currentBath: 0,
  },
};

function blankItemState() {
  return { checked: false, qty: '', year: '' };
}

function initState() {
  state.items = {};
  state.photos = {};
  CATEGORIES.forEach(cat => {
    if (cat.type === 'multi') return;
    cat.items.forEach(item => { state.items[item.id] = blankItemState(item); });
  });
  state.bathrooms.instances.forEach(bath => {
    BATH_CAT.items.forEach(item => { state.items[`${bath.id}:${item.id}`] = { checked: false, qty: '', year: '' }; });
  });
}

function loadProjectIntoState(proj) {
  state.currentProjectId = proj.id;
  state.currentProjectName = proj.name;
  state.items = proj.items || {};
  state.photos = proj.photos || {};
  state.bathrooms.instances = proj.bathroomInstances || [{ id: 'b1', name: 'Bathroom 1' }, { id: 'b2', name: 'Bathroom 2' }];
  state.bathrooms.currentBath = 0;
  state.currentCat = 0;
  state.showSummary = false;
  // Fill in any missing keys (new items added since save)
  CATEGORIES.forEach(cat => {
    if (cat.type === 'multi') return;
    cat.items.forEach(item => { if (!state.items[item.id]) state.items[item.id] = blankItemState(item); });
  });
  state.bathrooms.instances.forEach(bath => {
    BATH_CAT.items.forEach(item => {
      const k = `${bath.id}:${item.id}`;
      if (!state.items[k]) state.items[k] = { checked: false, qty: '', year: '' };
    });
  });
}

// ============================================================
// HELPERS
// ============================================================
function fmtTotal(n) { return '$' + Math.round(n).toLocaleString('en-US'); }

function fmtDate(iso) {
  if (!iso) return '';
  try { return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }); }
  catch { return ''; }
}

function getItemCost(item) {
  const ov = state.priceOverrides[item.id];
  return ov !== undefined ? ov : item.cost;
}

function parseCsvLine(line) {
  const result = []; let cur = ''; let inQ = false;
  for (let i = 0; i < line.length; i++) {
    const c = line[i];
    if (c === '"') { if (inQ && line[i+1] === '"') { cur += '"'; i++; } else inQ = !inQ; }
    else if (c === ',' && !inQ) { result.push(cur.trim()); cur = ''; }
    else cur += c;
  }
  result.push(cur.trim()); return result;
}
function parseCSV(text) {
  const lines = text.trim().split(/\r?\n/);
  const headers = parseCsvLine(lines[0]);
  return lines.slice(1).filter(l => l.trim()).map(line => {
    const vals = parseCsvLine(line);
    return Object.fromEntries(headers.map((h, i) => [h.trim(), vals[i] ?? '']));
  });
}

function findItemDef(id) {
  if (id.includes(':')) { const iid = id.split(':')[1]; return BATH_CAT.items.find(i => i.id === iid) || null; }
  return CATEGORIES.flatMap(c => c.items).find(i => i.id === id) || null;
}

function calcItem(item, s) {
  if (!s || !s.checked) return 0;
  const q = parseFloat(s.qty);
  if (!q || q <= 0) return 0;
  const raw = q * getItemCost(item);
  return item.min ? Math.max(raw, item.min) : raw;
}

function calcBathTotal(bath) {
  return BATH_CAT.items.reduce((t, item) => t + calcItem(item, state.items[`${bath.id}:${item.id}`]), 0);
}

function calcCategoryTotal(cat) {
  if (cat.type === 'multi') return state.bathrooms.instances.reduce((t, b) => t + calcBathTotal(b), 0);
  return cat.items.reduce((t, item) => t + calcItem(item, state.items[item.id]), 0);
}

function calcRunningTotal() { return CATEGORIES.reduce((t, cat) => t + calcCategoryTotal(cat), 0); }

function calcProgressUnits() {
  const itemToGroup = {};
  for (const [gid, g] of Object.entries(GROUPS)) {
    for (const id of g.ids) itemToGroup[id] = gid;
  }
  let total = 0, checked = 0;
  for (const cat of CATEGORIES) {
    if (cat.type === 'multi') {
      for (const bath of state.bathrooms.instances) {
        const seen = new Set();
        for (const item of BATH_CAT.items) {
          const gid = itemToGroup[item.id];
          if (gid) {
            const key = `${bath.id}:${gid}`;
            if (!seen.has(key)) {
              seen.add(key);
              total++;
              if (GROUPS[gid].ids.some(id => state.items[`${bath.id}:${id}`]?.checked)) checked++;
            }
          } else {
            total++;
            if (state.items[`${bath.id}:${item.id}`]?.checked) checked++;
          }
        }
      }
    } else {
      const seen = new Set();
      for (const item of cat.items) {
        const gid = itemToGroup[item.id];
        if (gid) {
          if (!seen.has(gid)) {
            seen.add(gid);
            total++;
            if (GROUPS[gid].ids.some(id => state.items[id]?.checked)) checked++;
          }
        } else {
          total++;
          if (state.items[item.id]?.checked) checked++;
        }
      }
    }
  }
  return { total, checked };
}

function checkedCount(cat) {
  if (cat.type === 'multi') return state.bathrooms.instances.reduce((t, b) =>
    t + BATH_CAT.items.filter(item => state.items[`${b.id}:${item.id}`]?.checked).length, 0);
  return cat.items.filter(item => state.items[item.id]?.checked).length;
}


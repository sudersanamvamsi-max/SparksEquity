function buildSlots(items, bathId) {
  const itemToGroup = {};
  for (const [gid, g] of Object.entries(GROUPS)) {
    for (const id of g.ids) itemToGroup[id] = gid;
  }
  const slots = [];
  const seenGroups = new Set();
  for (const item of items) {
    const gid = itemToGroup[item.id];
    if (gid) {
      if (!seenGroups.has(gid)) {
        seenGroups.add(gid);
        const groupItems = GROUPS[gid].ids.map(id => items.find(i => i.id === id)).filter(Boolean);
        const entries = groupItems.map(it => ({ item: it, stateId: bathId ? `${bathId}:${it.id}` : it.id }));
        slots.push({ type: 'group', gid, label: GROUPS[gid].label, entries });
      }
    } else {
      slots.push({ type: 'standalone', item, stateId: bathId ? `${bathId}:${item.id}` : item.id });
    }
  }
  return slots;
}

function renderGroup(slot) {
  const { gid, label, entries } = slot;
  const isExpanded = state.expandedGroups.includes(gid);
  const checkedInGroup = entries.filter(e => state.items[e.stateId]?.checked).length;
  const groupTotal = entries.reduce((sum, e) => sum + calcItem(e.item, state.items[e.stateId]), 0);
  const chevron = isExpanded
    ? `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="18 15 12 9 6 15"/></svg>`
    : `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>`;
  return `
    <div data-group-card data-gid="${gid}" class="bg-white rounded-2xl mb-2.5 shadow-sm overflow-hidden ${checkedInGroup > 0 ? 'ring-1 ring-orange-200' : ''}">
      <button data-action="toggle-group" data-gid="${gid}"
        class="w-full flex items-center justify-between px-4 py-3.5 text-left">
        <div class="flex items-center gap-2.5 min-w-0">
          <span class="text-gray-400 flex-shrink-0">${chevron}</span>
          <span class="font-semibold text-sm text-gray-800">${label}</span>
          ${checkedInGroup > 0 ? `<span class="text-xs px-2 py-0.5 bg-orange-100 text-orange-600 rounded-full font-medium flex-shrink-0">${checkedInGroup} ✓</span>` : ''}
        </div>

async function exportPackage() {
  if (typeof XLSX === 'undefined') { alert('Export library not loaded. Check your internet connection.'); return; }
  if (typeof JSZip === 'undefined') { alert('ZIP library not loaded. Check your internet connection.'); return; }

  const wb = XLSX.utils.book_new();
  const ws = {};
  let row = 0;
  const merges = [];
  const colWidths = [38, 16, 12, 10, 14];

  const s = (font, fill, align, border) => ({
    font: { name: 'Calibri', ...font },
    fill: fill ? { patternType: 'solid', fgColor: { rgb: fill } } : undefined,
    alignment: { wrapText: false, ...align },
    border: border || undefined,
  });

  const cell = (r, c, v, style, fmt) => {
    const addr = XLSX.utils.encode_cell({ r, c });
    ws[addr] = { v, t: typeof v === 'number' ? 'n' : 's', s: style };
    if (fmt) ws[addr].z = fmt;
  };
  const merge = (r, c1, c2) => merges.push({ s: { r, c: c1 }, e: { r, c: c2 } });

  // Title
  cell(row, 0, 'SPARK EQUITY GROUP — REPAIR ESTIMATE',
    s({ bold: true, sz: 14, color: { rgb: 'FFFFFF' } }, '111827', { horizontal: 'center', vertical: 'center' }));
  merge(row, 0, 4); row++;

  cell(row, 0, `Property: ${state.currentProjectName}     Date: ${new Date().toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'})}`,
    s({ sz: 10, color: { rgb: '6B7280' } }, 'F9FAFB', { horizontal: 'center' }));
  merge(row, 0, 4); row++;
  row++; // blank

  const thinBorder = (col) => ({ top: { style: 'thin', color: { rgb: col } }, bottom: { style: 'thin', color: { rgb: col } }, left: { style: 'thin', color: { rgb: col } }, right: { style: 'thin', color: { rgb: col } } });

  const processSection = (label, rows) => {
    if (!rows.length) return;
    // Section header
    cell(row, 0, label.toUpperCase(), s({ bold: true, sz: 11, color: { rgb: 'FFFFFF' } }, 'EA580C', { vertical: 'center' }));
    for (let c = 1; c < 5; c++) cell(row, c, '', s({}, 'EA580C'));
    merge(row, 0, 4); row++;

    // Column headers
    ['Repair Item','Unit','Unit Cost','Qty','Estimate'].forEach((h, c) =>
      cell(row, c, h, s({ bold: true, sz: 10, color: { rgb: '374151' } }, 'FFF7ED', { horizontal: c >= 2 ? 'right' : 'left' }, thinBorder('FDBA74'))));
    row++;

    let secTotal = 0;
    rows.forEach(({ item, s: st, t }) => {
      const rowStyle = s({ sz: 10, color: { rgb: '374151' } }, 'FFFFFF', {}, thinBorder('F3F4F6'));
      const yearStr = item.hasYear && st.year ? ` (${st.year})` : '';
      cell(row, 0, item.name + yearStr, rowStyle);
      cell(row, 1, item.unit, rowStyle);
      cell(row, 2, getItemCost(item), s({ sz: 10 }, 'FFFFFF', { horizontal: 'right' }, thinBorder('F3F4F6')), '"$"#,##0.00');
      cell(row, 3, parseFloat(st.qty) || 0, s({ sz: 10 }, 'FFFFFF', { horizontal: 'right' }, thinBorder('F3F4F6')));
      cell(row, 4, t, s({ sz: 10 }, 'FFFFFF', { horizontal: 'right' }, thinBorder('F3F4F6')), '"$"#,##0');
      secTotal += t; row++;
    });

    // Section total row
    const totStyle = s({ bold: true, sz: 10, color: { rgb: 'C2410C' } }, 'FFF7ED', {}, thinBorder('FDBA74'));
    cell(row, 0, `${label} Total`, totStyle); merge(row, 0, 3);
    for (let c = 1; c < 4; c++) cell(row, c, '', totStyle);
    cell(row, 4, secTotal, s({ bold: true, sz: 10, color: { rgb: 'C2410C' } }, 'FFF7ED', { horizontal: 'right' }, thinBorder('FDBA74')), '"$"#,##0');
    row++;
    row++; // blank
  };

  CATEGORIES.forEach(cat => {
    if (cat.type === 'multi') {
      state.bathrooms.instances.forEach(bath => {
        const rows = BATH_CAT.items
          .filter(item => { const st = state.items[`${bath.id}:${item.id}`]; return st?.checked && parseFloat(st.qty) > 0; })
          .map(item => ({ item, s: state.items[`${bath.id}:${item.id}`], t: calcItem(item, state.items[`${bath.id}:${item.id}`]) }));
        processSection(bath.name, rows);
      });
    } else {
      const rows = cat.items
        .filter(item => { const st = state.items[item.id]; return st?.checked && parseFloat(st.qty) > 0; })
        .map(item => ({ item, s: state.items[item.id], t: calcItem(item, state.items[item.id]) }));
      processSection(cat.name, rows);
    }
  });

  // Grand total
  const grand = calcRunningTotal();
  cell(row, 0, 'TOTAL ESTIMATE', s({ bold: true, sz: 13, color: { rgb: 'FFFFFF' } }, '111827', { horizontal: 'center', vertical: 'center' }));
  merge(row, 0, 3);
  for (let c = 1; c < 4; c++) cell(row, c, '', s({}, '111827'));
  cell(row, 4, grand, s({ bold: true, sz: 13, color: { rgb: 'FFFFFF' } }, '111827', { horizontal: 'right', vertical: 'center' }), '"$"#,##0');

  ws['!ref'] = XLSX.utils.encode_range({ s: { r: 0, c: 0 }, e: { r: row, c: 4 } });
  ws['!cols'] = colWidths.map(w => ({ wch: w }));
  ws['!merges'] = merges;
  ws['!rows'] = Array.from({ length: row + 1 }, (_, i) => ({ hpt: i === 0 ? 24 : i === 1 ? 16 : 18 }));

  XLSX.utils.book_append_sheet(wb, ws, 'Estimate');
  const baseName = `Repair-Estimate-${state.currentProjectName.replace(/[^a-z0-9]/gi,'_')}-${new Date().toISOString().split('T')[0]}`;

  const photoEntries = Object.entries(state.photos || {}).filter(([, arr]) => arr?.length > 0);
  if (!photoEntries.length) {
    XLSX.writeFile(wb, `${baseName}.xlsx`);
    return;
  }

  // Bundle Excel + photos into a ZIP
  const zip = new JSZip();
  zip.file(`${baseName}.xlsx`, XLSX.write(wb, { bookType: 'xlsx', type: 'array' }));
  const folder = zip.folder('photos');
  photoEntries.forEach(([stateId, photos]) => {
    const def = findItemDef(stateId);
    const prefix = (def?.name || stateId).replace(/[^a-z0-9]/gi, '_');
    photos.forEach((ph, i) => {
      const ext = (ph.dataUrl.split(';')[0].split('/')[1] || 'jpg').replace('jpeg', 'jpg');
      folder.file(`${prefix}_${i + 1}.${ext}`, ph.dataUrl.split(',')[1], { base64: true });
    });
  });
  const blob = await zip.generateAsync({ type: 'blob' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `${baseName}.zip`;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(a.href);
}

// ============================================================
// EVENTS  (bound once on body via delegation)
// ============================================================
function bindEvents() {
  // click/input delegated to body once on boot; this just re-binds nothing extra
}

document.body.addEventListener('click', e => {
  const btn = e.target.closest('[data-action]');
  if (!btn) return;
  const action = btn.dataset.action;

  if (action === 'open-panel')       { openPanel(); return; }
  if (action === 'open-settings')    { openSettings(); return; }
  if (action === 'export-excel')     { exportPackage(); return; }

  if (action === 'toggle-item') {
    const id = btn.dataset.id;
    const s = state.items[id];
    s.checked = !s.checked;
    if (!s.checked) s.qty = '';
    saveCurrentState(); render();
    if (s.checked) document.querySelector(`[data-action="update-qty"][data-id="${id}"]`)?.focus();
    return;
  }
  if (action === 'switch-cat') {
    state.currentCat = parseInt(btn.dataset.index);
    render();
    document.getElementById('scroll-area')?.scrollTo(0,0);
    return;
  }
  if (action === 'prev-cat') {
    state.currentCat = Math.max(0, state.currentCat - 1);
    render(); document.getElementById('scroll-area')?.scrollTo(0,0); return;
  }
  if (action === 'next-cat') {
    state.currentCat = Math.min(CATEGORIES.length - 1, state.currentCat + 1);
    render(); document.getElementById('scroll-area')?.scrollTo(0,0); return;
  }
  if (action === 'toggle-group') {
    const gid = btn.dataset.gid;
    const scrollEl = document.getElementById('scroll-area');
    const scrollTop = scrollEl ? scrollEl.scrollTop : 0;
    const idx = state.expandedGroups.indexOf(gid);
    if (idx >= 0) state.expandedGroups.splice(idx, 1); else state.expandedGroups.push(gid);
    render();
    if (scrollEl) requestAnimationFrame(() => document.getElementById('scroll-area')?.scrollTo(0, scrollTop));
    return;
  }
  if (action === 'switch-bath') {
    state.bathrooms.currentBath = parseInt(btn.dataset.index);
    render(); document.getElementById('scroll-area')?.scrollTo(0,0); return;
  }
  if (action === 'edit-bath-name') {
    const idx = parseInt(btn.dataset.index);
    openModal('Rename Bathroom', 'e.g. Master Bath', state.bathrooms.instances[idx].name, name => {
      state.bathrooms.instances[idx].name = name;
      saveCurrentState(); render();
    });
    return;
  }
  if (action === 'add-bath') {
    const id = `b${Date.now()}`;
    const name = `Bathroom ${state.bathrooms.instances.length + 1}`;
    state.bathrooms.instances.push({ id, name });
    BATH_CAT.items.forEach(item => { state.items[`${id}:${item.id}`] = { checked: false, qty: '', year: '' }; });
    state.bathrooms.currentBath = state.bathrooms.instances.length - 1;
    saveCurrentState(); render(); return;
  }
  if (action === 'remove-bath') {
    const idx = parseInt(btn.dataset.index);
    const bath = state.bathrooms.instances[idx];
    if (!confirm(`Remove "${bath.name}"? All entries will be lost.`)) return;
    BATH_CAT.items.forEach(item => { delete state.items[`${bath.id}:${item.id}`]; });
    state.bathrooms.instances.splice(idx, 1);
    state.bathrooms.currentBath = Math.min(state.bathrooms.currentBath, state.bathrooms.instances.length - 1);
    saveCurrentState(); render(); return;
  }
  if (action === 'rename-project') {
    openModal('Rename Project', 'e.g. 123 Main St', state.currentProjectName, name => {
      state.currentProjectName = name;
      saveCurrentState();
      render();
    });
    return;
  }
  if (action === 'add-photo') {
    const id = btn.dataset.id;
    const input = document.createElement('input');
    input.type = 'file';
    input.accept = 'image/*';
    input.capture = 'environment';
    input.style.cssText = 'position:fixed;top:-999px;opacity:0';
    document.body.appendChild(input);   // must be in DOM or Android drops the event
    input.onchange = async () => {
      document.body.removeChild(input);
      if (!input.files || !input.files.length) return;
      if (!state.photos[id]) state.photos[id] = [];
      for (const file of Array.from(input.files)) {
        const dataUrl = await compressImage(file);
        state.photos[id].push({ name: file.name, dataUrl });
      }
      saveCurrentState(); render();
    };
    input.click();
    return;
  }
  if (action === 'remove-photo') {
    const id = btn.dataset.id;
    const idx = parseInt(btn.dataset.index);
    if (state.photos[id]) state.photos[id].splice(idx, 1);
    scheduleSave(); render();
    return;
  }
  if (action === 'show-summary')  { state.showSummary = true;  saveCurrentState(); render(); return; }
  if (action === 'back-to-edit')  { state.showSummary = false; render(); return; }
  if (action === 'reset') {
    if (!confirm('Start a new estimate? All entries will be cleared.')) return;
    state.bathrooms.instances = [{ id: 'b1', name: 'Bathroom 1' }, { id: 'b2', name: 'Bathroom 2' }];
    state.bathrooms.currentBath = 0;
    state.currentCat = 0;
    state.showSummary = false;
    initState();
    saveCurrentState(); render(); return;
  }
});


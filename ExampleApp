function openPanel() {
  refreshPanelList();
  document.getElementById('side-panel').classList.remove('-translate-x-full');
  document.getElementById('panel-overlay').classList.remove('hidden');
}

function closePanel() {
  document.getElementById('side-panel').classList.add('-translate-x-full');
  document.getElementById('panel-overlay').classList.add('hidden');
}

function refreshPanelList() {
  const list = loadProjects();
  const panelList = document.getElementById('panel-list');
  panelList.innerHTML = list.length === 0
    ? '<p class="text-center text-gray-400 text-sm py-10">No saved projects</p>'
    : list.map(p => {
        const isActive = p.id === state.currentProjectId;
        const safeName = p.name.replace(/"/g, '&quot;');
        return `<div class="border-b border-gray-50 flex items-stretch ${isActive ? 'bg-orange-50' : ''}">
          <button class="panel-proj-btn flex-1 text-left px-4 py-4" data-proj-id="${p.id}">
            <p class="font-semibold text-sm ${isActive ? 'text-orange-700' : 'text-gray-900'}">${p.name}</p>
            <p class="text-xs text-gray-400 mt-0.5">${fmtDate(p.savedAt)}</p>
            ${isActive ? '<span class="text-orange-400 text-xs font-medium block mt-1">Active</span>' : ''}
          </button>
          <div class="flex flex-col justify-center gap-1 pr-3">
            <button class="panel-rename-btn p-2 rounded-lg text-gray-400" data-proj-id="${p.id}" data-proj-name="${safeName}" title="Rename">${PENCIL}</button>
            ${!isActive ? `<button class="panel-delete-btn p-2 rounded-lg text-red-300" data-proj-id="${p.id}" data-proj-name="${safeName}" title="Delete">${TRASH}</button>` : ''}
          </div>
        </div>`;
      }).join('');

  panelList.querySelectorAll('.panel-proj-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.projId;
      if (id === state.currentProjectId) { closePanel(); return; }
      saveCurrentState();
      const proj = loadProjects().find(p => p.id === id);
      if (proj) { loadProjectIntoState(proj); render(); closePanel(); }
    });
  });

  panelList.querySelectorAll('.panel-rename-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.projId;
      openModal('Rename Project', 'e.g. 123 Main St', btn.dataset.projName, name => {
        const saved = loadProjects();
        const proj = saved.find(p => p.id === id);
        if (proj) {
          proj.name = name;
          saveProjects(saved);
          if (id === state.currentProjectId) { state.currentProjectName = name; render(); }
        }
        refreshPanelList();
      });
    });
  });

  panelList.querySelectorAll('.panel-delete-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.projId;
      if (!confirm(`Delete "${btn.dataset.projName}"? This cannot be undone.`)) return;
      saveProjects(loadProjects().filter(p => p.id !== id));
      refreshPanelList();
    });
  });
}

